<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ShopEase</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    background: #0f172a;
    color: white;
}

/* HEADER */
header {
    display: flex;
    justify-content: space-between;
    padding: 20px;
    background: #020617;
    font-size: 20px;
}

/* SEARCH */
.search-box {
    text-align: center;
    margin: 20px;
}

.search-box input {
    width: 50%;
    padding: 10px;
    border-radius: 20px;
    border: none;
}

/* FILTER */
.filters {
    text-align: center;
    margin-bottom: 20px;
}

.filters button {
    margin: 5px;
    padding: 8px 15px;
    border: none;
    border-radius: 20px;
    background: #1e293b;
    color: white;
    cursor: pointer;
}

/* GRID */
.container {
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
    gap: 20px;
    padding: 20px;
}

/* CARD */
.card {
    background: #1e293b;
    border-radius: 15px;
    overflow: hidden;
    position: relative;
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-8px);
}

/* IMAGE EFFECT */
.card img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    transition: 0.4s;
}

.card:hover img {
    transform: scale(1.1);
    filter: brightness(0.7);
}

/* OVERLAY */
.overlay {
    position: absolute;
    bottom: 0;
    width: 100%;
    text-align: center;
    padding: 10px;
    background: rgba(0,0,0,0.6);
    opacity: 0;
    transition: 0.3s;
}

.card:hover .overlay {
    opacity: 1;
}

/* CONTENT */
.card-content {
    padding: 15px;
}

.price {
    color: #38bdf8;
    font-weight: bold;
}

/* BUTTONS */
.actions button {
    margin-top: 8px;
    padding: 8px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
}

.cart-btn {
    background: #38bdf8;
}

.wishlist-btn {
    background: #ef4444;
}

</style>
</head>

<body>

<header>
<div>🛍️ ShopEase</div>
<div>Cart 🛒</div>
</header>

<div class="search-box">
<input type="text" id="search" placeholder="Search products...">
</div>

<div class="filters">
<button onclick="filterCategory('all')">All</button>
<button onclick="filterCategory('electronics')">Electronics</button>
<button onclick="filterCategory('fashion')">Fashion</button>
</div>

<div class="container" id="products">

<!-- PRODUCT 1 -->
<div class="card electronics">
<img src="https://images.unsplash.com/photo-1518441902110-1c2c1d5b1f5d">
<div class="overlay">View Product</div>
<div class="card-content">
<h3>Headphones</h3>
<p class="price">₹1999</p>
<div class="actions">
<button class="cart-btn">Add to Cart</button>
<button class="wishlist-btn">♥</button>
</div>
</div>
</div>

<!-- PRODUCT 2 -->
