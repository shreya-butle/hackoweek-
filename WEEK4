</div>
</div>
</div>

<!-- PRODUCT 3 -->
<div class="card electronics">
<img src="https://images.unsplash.com/photo-1519741497674-611481863552">
<div class="overlay">View Product</div>
<div class="card-content">
<h3>Smart Watch</h3>
<p class="price">₹2999</p>
<div class="actions">
<button class="cart-btn">Add to Cart</button>
<button class="wishlist-btn">♥</button>
</div>
</div>
</div>

<!-- PRODUCT 4 -->
<div class="card fashion">
<img src="https://images.unsplash.com/photo-1528701800489-20be3c0b2c3c">
<div class="overlay">View Product</div>
<div class="card-content">
<h3>Shoes</h3>
<p class="price">₹1499</p>
<div class="actions">
<button class="cart-btn">Add to Cart</button>
<button class="wishlist-btn">♥</button>
</div>
</div>
</div>

<!-- PRODUCT 5 -->
<div class="card electronics">
<img src="https://images.unsplash.com/photo-1517336714731-489689fd1ca8">
<div class="overlay">View Product</div>
<div class="card-content">
<h3>Laptop</h3>
<p class="price">₹55000</p>
<div class="actions">
