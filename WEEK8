```html
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Professional Photography Gallery</title>

<style>

body{
font-family: 'Segoe UI', sans-serif;
margin:0;
background:#111;
color:white;
text-align:center;
}

h1{
margin:20px;
letter-spacing:2px;
}

/* FILTER BUTTONS */

.filters{
margin-bottom:20px;
}

.filters button{
padding:10px 18px;
margin:6px;
border:none;
background:#222;
color:white;
cursor:pointer;
border-radius:20px;
transition:.3s;
}

.filters button:hover{
background:#ff4c4c;
}

/* GALLERY */

.gallery{
column-count:3;
column-gap:15px;
padding:20px;
max-width:1200px;
margin:auto;
}

.gallery img{
width:100%;
margin-bottom:15px;
border-radius:10px;
cursor:pointer;
transition:0.3s;
}

.gallery img:hover{
transform:scale(1.05);
box-shadow:0 10px 25px rgba(0,0,0,.6);
}

/* LIGHTBOX */

.lightbox{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,.95);
display:none;
align-items:center;
justify-content:center;
flex-direction:column;
animation:fade .4s;
}

@keyframes fade{
from{opacity:0}
to{opacity:1}
}

.lightbox img{
max-width:80%;
max-height:70%;
border-radius:10px;
}

.caption{
margin-top:10px;
font-size:18px;
}

.close{
position:absolute;
top:20px;
right:40px;
font-size:40px;
cursor:pointer;
}

.nav{
position:absolute;
top:50%;
font-size:50px;
cursor:pointer;
user-select:none;
}

.prev{ left:40px; }
.next{ right:40px; }

/* TOOLBAR */

.toolbar{
margin-top:15px;
}

.toolbar button{
padding:8px 14px;
margin:5px;
border:none;
border-radius:5px;
background:#ff4c4c;
color:white;
cursor:pointer;
}

/* RESPONSIVE */

@media(max-width:900px){
.gallery{column-count:2;}
}

@media(max-width:500px){
.gallery{column-count:1;}
}

</style>
</head>

<body>

<h1>📸 Professional Photography Gallery</h1>

<div class="filters">
<button onclick="filterImages('all')">All</button>
<button onclick="filterImages('nature')">Nature</button>
<button onclick="filterImages('city')">City</button>
<button onclick="filterImages('portrait')">Portrait</button>
</div>

<div class="gallery">

<img src="https://picsum.photos/id/1015/600/400" class="nature" data-caption="Mountain Lake" onclick="openLightbox(0)">
<img src="https://picsum.photos/id/1011/600/500" class="nature" data-caption="Forest Path" onclick="openLightbox(1)">
<img src="https://picsum.photos/id/1016/600/450" class="nature" data-caption="Nature Landscape" onclick="openLightbox(2)">

<img src="https://picsum.photos/id/1027/600/500" class="portrait" data-caption="Portrait Shot" onclick="openLightbox(3)">
<img src="https://picsum.photos/id/1025/600/450" class="portrait" data-caption="Dog Portrait" onclick="openLightbox(4)">
<img src="https://picsum.photos/id/1005/600/400" class="portrait" data-caption="Classic Portrait" onclick="openLightbox(5)">

<img src="https://picsum.photos/id/1031/600/450" class="city" data-caption="City Skyline" onclick="openLightbox(6)">
<img src="https://picsum.photos/id/1035/600/500" class="city" data-caption="Urban Architecture" onclick="openLightbox(7)">
<img src="https://picsum.photos/id/1043/600/450" class="city" data-caption="Night City" onclick="openLightbox(8)">

</div>

<!-- LIGHTBOX -->

<div class="lightbox" id="lightbox">

<span class="close" onclick="closeLightbox()">✖</span>

<span class="nav prev" onclick="changeImage(-1)">❮</span>

<img id="lightbox-img">

<span class="nav next" onclick="changeImage(1)">❯</span>

<div class="caption" id="caption"></div>

<div class="toolbar">
<button onclick="downloadImage()">Download</button>
<button onclick="toggleSlideshow()">Slideshow</button>
<button onclick="openFullscreen()">Fullscreen</button>
</div>

</div>

<script>

const images = document.querySelectorAll(".gallery img");
const lightbox = document.getElementById("lightbox");
const lightboxImg = document.getElementById("lightbox-img");
const caption = document.getElementById("caption");

let index=0;
let slideshow;

/* OPEN */

function openLightbox(i){
index=i;
lightbox.style.display="flex";
showImage();
}

/* CLOSE */

function closeLightbox(){
lightbox.style.display="none";
clearInterval(slideshow);
}

/* SHOW IMAGE */

function showImage(){
lightboxImg.src=images[index].src;
caption.innerText=images[index].dataset.caption;
}

/* NAVIGATION */

function changeImage(n){
index+=n;

if(index>=images.length) index=0;
if(index<0) index=images.length-1;

showImage();
}

/* KEYBOARD */

document.addEventListener("keydown",function(e){

if(lightbox.style.display==="flex"){

if(e.key==="ArrowRight") changeImage(1);
if(e.key==="ArrowLeft") changeImage(-1);
if(e.key==="Escape") closeLightbox();

}

});

/* FILTER */

function filterImages(category){

images.forEach(img=>{

if(category==="all"){
img.style.display="block";
}else{
img.style.display=img.classList.contains(category)?"block":"none";
}

});

}

/* DOWNLOAD */

function downloadImage(){
const link=document.createElement("a");
link.href=lightboxImg.src;
link.download="photo.jpg";
link.click();
}

/* SLIDESHOW */

function toggleSlideshow(){

if(slideshow){
clearInterval(slideshow);
slideshow=null;
}else{
slideshow=setInterval(()=>changeImage(1),2000);
}

}

/* FULLSCREEN */

function openFullscreen(){

if(lightbox.requestFullscreen){
lightbox.requestFullscreen();
}

}

</script>

</body>
</html>
